option_settings:
  aws:elasticbeanstalk:application:environment:
    # AWS region
    AWS_REGION: eu-north-1

    # Spring datasource credentials — injected via workflow secrets into EB environment variables.

    # SQS queue URLs — set per-environment in the EB console or override below
    AWS_SQS_HEART_RATE_SERIES_QUEUE_URL: "https://sqs.eu-north-1.amazonaws.com/405633560433/HearRateSeriesQueue"
    AWS_SQS_SLEEP_SESSION_QUEUE_URL: "https://sqs.eu-north-1.amazonaws.com/405633560433/SleepSessionQueue"
    AWS_SQS_EXERCISE_SESSION_QUEUE_URL: "https://sqs.eu-north-1.amazonaws.com/405633560433/ExerciseSessionQueue"
    AWS_SQS_DAILY_SUMMARY_QUEUE_URL: "https://sqs.eu-north-1.amazonaws.com/405633560433/DailySummaryQueue"

    # SQS tuning
    SQS_MAX_CONCURRENT_MESSAGES: "100"
    SQS_MAX_MESSAGES_PER_POLL: "10"

    # Server port — EB nginx reverse-proxy forwards port 80 → 5000
    PORT: "5000"